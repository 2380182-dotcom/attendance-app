# ===============================
# Backend Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ===============================

# Database (MySQL for local dev, PostgreSQL for Render production)
DB_URL=jdbc:mysql://localhost:3306/attendance_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=springuser
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# Server
PORT=8080

# JWT — use a long random string (min 32 characters)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRATION_MS=864000000

# Spring profile: leave empty for dev, set to "prod" for production
SPRING_PROFILES_ACTIVE=

# JPA (production should use "validate")
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# CORS — comma-separated allowed origins (* for local mobile dev)
CORS_ALLOWED_ORIGINS=*

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=300
