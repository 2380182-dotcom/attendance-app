# ===============================
# Mobile Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ===============================

# Backend API URL (must include /api suffix)
EXPO_PUBLIC_API_URL=http://localhost:8080/api

# Google Maps API key (required for map features)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

# On-device face verification threshold (0.0–1.0)
EXPO_PUBLIC_FACE_CONFIDENCE_THRESHOLD=0.85
EXPO_PUBLIC_FACE_MAX_ATTEMPTS=3
