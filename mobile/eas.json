{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8080/api",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "YOUR_GOOGLE_MAPS_KEY_HERE"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://attendance-app-rn2m.onrender.com/api",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "YOUR_GOOGLE_MAPS_KEY_HERE"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://attendance-app-rn2m.onrender.com/api",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "YOUR_GOOGLE_MAPS_KEY_HERE"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
